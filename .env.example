# ─────────────────────────────────────────────────────────────────
# Caminhos da aplicação (usados pelo container post-trade-mkt)
# ─────────────────────────────────────────────────────────────────
SRC_DOWNLOADS=/app/downloads
SRC_EXTRAIDOS=/app/extraidos

# ─────────────────────────────────────────────────────────────────
# Airflow — segredos obrigatórios para produção
# Em desenvolvimento local os valores abaixo funcionam por padrão.
# Para qualquer ambiente exposto, substitua por valores únicos e
# gerados aleatoriamente (ex: openssl rand -hex 32).
# ─────────────────────────────────────────────────────────────────
AIRFLOW_DB_PASSWORD=airflow
AIRFLOW_SECRET_KEY=mude-esta-chave-em-producao
AIRFLOW_JWT_SECRET=mude-este-secret-em-producao
AIRFLOW_ADMIN_PASSWORD=admin
