# ─────────────────────────────────────────────────────────────────
# Caminhos da aplicação (usados pelo container post-trade-mkt)
# ─────────────────────────────────────────────────────────────────
SRC_DOWNLOADS=/app/downloads
SRC_EXTRAIDOS=/app/extraidos

# ─────────────────────────────────────────────────────────────────
# Airflow — segredos obrigatórios
#
# Copie este arquivo para .env e preencha com valores próprios.
# O ambiente NÃO sobe sem estas variáveis definidas.
#
# Para gerar valores seguros para SECRET_KEY e JWT_SECRET:
#   openssl rand -hex 32
# ─────────────────────────────────────────────────────────────────
AIRFLOW_DB_PASSWORD=
AIRFLOW_ADMIN_PASSWORD=
AIRFLOW_SECRET_KEY=
AIRFLOW_JWT_SECRET=
